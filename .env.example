# Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is safe to commit.

# Vapi
VAPI_API_KEY=your_vapi_api_key_here
ASSISTANT_ID=your_eric_assistant_id
PHONE_NUMBER_ID=your_vapi_phone_number_id

# QStash (Upstash)
QSTASH_TOKEN=your_qstash_token

# Render
RENDER_BASE_URL=https://your-render-service.onrender.com

# Operator authentication for /start-call. If set, the server requires
# requests to include an X-API-Key header matching this value. If unset,
# /start-call is open to anyone with the URL (development only).
# Generate something hard to guess, e.g. `openssl rand -hex 32`.
START_CALL_API_KEY=set_a_secret_here

# Interview config
INTERVIEW_MAX_MINUTES=45
WRAPUP_OFFSET_MINUTES=2
# Optional, default 30. Seconds before the hard cap when the force-close fires
# (Vapi force-speaks the closing line and auto-hangs up if Eric hasn't
# already invoked schedule_next_session).
FORCE_CLOSE_OFFSET_SECONDS=30
# Optional, default 10. Callbacks requested with delay shorter than this are
# routed through QStash (more accurate); longer delays use Vapi's native
# schedulePlan.
QSTASH_CALLBACK_THRESHOLD_MINUTES=10
SCREENING_QUESTIONS_JSON=[{"id":1,"question":"Do you currently use a cookstove?","pass_answer":"yes"}]
# Optional, default "true". When "true", Imani reads the formal consent
# statement and waits for explicit yes/no before screening starts. Set to
# "false" to skip the consent step (useful for fast iteration during
# testing). Read fresh per call, so toggling in Render takes effect on
# the next dial.
CONSENT_STATEMENT_ENABLED=true

# KrosAI (BYO trunk for Nigeria). Read-only API access for inspecting
# call detail records when investigating dial failures or duration
# discrepancies with Vapi. Create the key in the KrosAI dashboard with
# Calls + Billing (read) permissions; do NOT grant API Keys permission.
KROSAI_API_KEY=your_krosai_api_key_here

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_public_jwt_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret_jwt_here
